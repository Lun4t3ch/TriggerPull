# TriggerPull has no required configuration — the SSI origin is hard-coded in
# functions/api/_ssi.js (https://shootnscoreit.com) and no secrets are stored.
#
# This file exists as a placeholder for any future config. For Cloudflare Pages
# Functions, local secrets/vars go in a `.dev.vars` file (gitignored), e.g.:
#
#   # .dev.vars
#   SSI_ORIGIN=https://shootnscoreit.com
#
# and in production via the Pages dashboard → Settings → Environment variables.
